{
  "name": "dutophy-monorepo",
  "private": true,
  "packageManager": "npm@10.0.0",
  "workspaces": [
    "apps/*"
  ],
  "scripts": {
    "dev": "turbo run dev --parallel",
    "dev:web": "turbo run dev --filter=@dcms/web",
    "dev:api": "turbo run dev --filter=@dcms/api",
    "build": "turbo run build",
    "lint": "turbo run lint",
    "db:push": "cd apps/api && npx drizzle-kit push",
    "db:studio": "cd apps/api && npx drizzle-kit studio"
  },
  "devDependencies": {
    "drizzle-kit": "^0.31.10",
    "drizzle-orm": "^0.45.2",
    "pg": "^8.21.0",
    "turbo": "^2.9.14"
  },
  "dependencies": {
    "@google/genai": "^2.7.0",
    "@react-oauth/google": "^0.13.5",
    "google-auth-library": "^10.7.0",
    "jwt-decode": "^4.0.0",
    "react-easy-crop": "^5.5.7"
  }
}
